# Copy this file to automation/harness/.env and adjust values.

REPO_FULL_NAME=gurioh/devformat
REPO_DIR=/absolute/path/to/devformat

# Labels used by the harness.
ISSUE_READY_LABEL=agent-ready
ISSUE_RUNNING_LABEL=agent-running
ISSUE_FAILED_LABEL=agent-failed
ISSUE_PR_LABEL=agent-pr-opened

# Git identity for automated commits.
GIT_AUTHOR_NAME=gurioh
GIT_AUTHOR_EMAIL=gurioh@users.noreply.github.com
GIT_COMMITTER_NAME=gurioh
GIT_COMMITTER_EMAIL=gurioh@users.noreply.github.com

# Command that should execute the coding agent.
# The command reads the generated prompt from stdin.
# Example:
# AGENT_COMMAND=codex exec --cwd "$REPO_DIR"
AGENT_COMMAND=

# Optional override for where run artifacts are stored.
# Defaults to automation/harness/runs
HARNESS_RUNS_DIR=
